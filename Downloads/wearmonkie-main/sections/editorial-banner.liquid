<section class="editorial section">
  <div class="editorial__inner container">
    <div class="editorial__text">
      {%- if section.settings.eyebrow != blank -%}
        <p class="editorial__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="editorial__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="editorial__body">{{ section.settings.body }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn--dark">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
    <div class="editorial__image">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 800
          | image_tag:
            loading: 'lazy',
            alt: section.settings.image.alt | default: section.settings.heading,
            widths: '400, 600, 800',
            sizes: '(min-width: 1024px) 50vw, 100vw'
        }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial Banner",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "The Edit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built for the Modern Woman" },
    { "type": "textarea", "id": "body", "label": "Body text" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Explore the Collection" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "image_picker", "id": "image", "label": "Image" }
  ],
  "presets": [{ "name": "Editorial Banner" }]
}
{% endschema %}
