{%- liquid
  assign collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show | default: 4
-%}

<section id="{{ section.id }}" class="featured section container">
  <div class="section__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="section__title">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if collection != blank -%}
      <a href="{{ collection.url }}" class="link-arrow">{{ 'sections.featured_collection.view_all' | t }} →</a>
    {%- endif -%}
  </div>

  <div class="products__grid">
    {%- if collection != blank and collection.products.size > 0 -%}
      {%- for product in collection.products limit: products_to_show -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..products_to_show) -%}
        <div class="product-card product-card--placeholder">
          <div class="product-card__img-wrap">
            {{ 'product-' | append: i | placeholder_svg_tag: 'product-card__img' }}
          </div>
          <div class="product-card__info">
            <h3 class="product-card__name">{{ 'onboarding.product_title' | t }}</h3>
            <div class="product-card__price"><span class="price">$0.00</span></div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Products" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 8, "step": 1, "label": "Products to show", "default": 4 }
  ],
  "presets": [{ "name": "Featured Collection" }]
}
{% endschema %}
