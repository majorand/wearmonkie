{% layout none %}
{%- liquid
  assign gc_balance_money = gift_card.balance | money
  assign gc_title = 'gift_cards.issued.title' | t: value: gc_balance_money, shop: shop.name
-%}
<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex,nofollow">
    <title>{{ gc_title }}</title>
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}
    {{ content_for_header }}
    {{ 'wearmonkie.css' | asset_url | stylesheet_tag }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
      .gc { min-height: 100vh; display: grid; place-items: center; padding: 2rem; background: var(--color-bg); }
      .gc__card { max-width: 460px; width: 100%; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); overflow: hidden; text-align: center; }
      .gc__head { background: var(--color-dark); color: #fff; padding: 2rem; }
      .gc__brand { font-family: var(--font-serif); font-size: 1.6rem; font-weight: 700; margin-bottom: .5rem; }
      .gc__label { font-size: 12px; letter-spacing: .2em; text-transform: uppercase; opacity: .8; }
      .gc__body { padding: 2rem; }
      .gc__balance { font-family: var(--font-serif); font-size: 3rem; font-weight: 700; color: var(--color-dark); line-height: 1; margin-bottom: .25rem; }
      .gc__expired-note { color: var(--color-sale); font-size: 13px; margin-bottom: 1rem; }
      .gc__code { font-family: monospace; font-size: 1.25rem; letter-spacing: .15em; background: var(--color-bg); border: 1px dashed var(--color-border); border-radius: var(--radius); padding: .85rem 1rem; margin: 1.25rem 0; color: var(--color-dark); }
      .gc__actions { display: flex; gap: .5rem; justify-content: center; flex-wrap: wrap; margin-top: 1rem; }
      .gc__note { font-size: 12px; color: var(--color-text-muted); margin-top: 1.25rem; }
      @media print { .gc__actions { display: none; } body { background: #fff; } }
    </style>
  </head>
  <body class="template-gift-card">
    <div class="gc">
      <div class="gc__card">
        <div class="gc__head">
          <p class="gc__brand">{{ shop.name }}</p>
          <p class="gc__label">{{ 'gift_cards.issued.subtext' | t | default: 'Gift Card' }}</p>
        </div>
        <div class="gc__body">
          <p class="gc__balance">{{ gift_card.balance | money }}</p>
          {%- if gift_card.expired -%}
            <p class="gc__expired-note">{{ 'gift_cards.issued.expired' | t | default: 'This gift card has expired.' }}</p>
          {%- elsif gift_card.expires_on -%}
            <p class="gc__note">{{ 'gift_cards.issued.expires_on' | t: expires_on: gift_card.expires_on | date: '%B %-d, %Y' | default: 'Valid through' }}</p>
          {%- endif -%}

          <p class="gc__code" aria-label="Gift card code">{{ gift_card.code | format_code }}</p>

          <div class="gc__actions">
            <button type="button" class="btn btn--primary" onclick="window.print()">{{ 'gift_cards.issued.print' | t | default: 'Print' }}</button>
            <a href="{{ shop.url }}" class="btn btn--outline">{{ 'gift_cards.issued.shop_link' | t | default: 'Start shopping' }}</a>
          </div>

          <p class="gc__note">{{ 'gift_cards.issued.redeem' | t | default: 'Use this code at checkout to redeem your gift card.' }}</p>
        </div>
      </div>
    </div>
  </body>
</html>
