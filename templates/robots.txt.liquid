{% comment %}
  Default Shopify robots.txt. Edit the groups in the Shopify admin or via robots.default_groups.
{% endcomment %}
{% for group in robots.default_groups %}
  {{- group.user_agent }}
  {% for rule in group.rules -%}
    {{ rule }}
  {% endfor -%}
  {%- if group.sitemap != blank -%}
    {{ group.sitemap }}
  {%- endif -%}
{% endfor %}
