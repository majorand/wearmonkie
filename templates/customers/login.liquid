<div class="customer container">
  <div class="customer__panel" id="login">
    <h1 class="customer__title">{{ 'customer.login.title' | t | default: 'Login' }}</h1>

    {%- form 'customer_login', novalidate: 'novalidate' -%}
      {%- if form.errors -%}
        <div class="customer__errors" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <label class="customer__label" for="customer_email">{{ 'customer.login.email' | t | default: 'Email' }}</label>
      <input type="email" name="customer[email]" id="customer_email" class="customer__input" autocomplete="email" autocorrect="off" autocapitalize="off" required>

      {%- if form.password_needed -%}
        <label class="customer__label" for="customer_password">{{ 'customer.login.password' | t | default: 'Password' }}</label>
        <input type="password" name="customer[password]" id="customer_password" class="customer__input" autocomplete="current-password" required>
        <a href="#recover" class="customer__link" onclick="document.getElementById('recover').hidden=false;document.getElementById('login').hidden=true;return false;">
          {{ 'customer.login.forgot_password' | t | default: 'Forgot your password?' }}
        </a>
      {%- endif -%}

      <button type="submit" class="btn btn--primary btn--lg customer__submit">{{ 'customer.login.sign_in' | t | default: 'Sign In' }}</button>
    {%- endform -%}

    {%- if shop.customer_accounts_enabled -%}
      <p class="customer__alt">
        {{ 'customer.login.new_customer' | t | default: 'New here?' }}
        <a href="{{ routes.account_register_url }}" class="customer__link">{{ 'customer.login.create_account' | t | default: 'Create an account' }}</a>
      </p>
    {%- endif -%}
  </div>

  <div class="customer__panel" id="recover" hidden>
    <h1 class="customer__title">{{ 'customer.recover_password.title' | t | default: 'Reset your password' }}</h1>
    <p class="customer__intro">{{ 'customer.recover_password.subtext' | t | default: "We'll send you an email to reset your password." }}</p>

    {%- form 'recover_customer_password' -%}
      {%- if form.posted_successfully? -%}
        <p class="customer__success" role="status">{{ 'customer.recover_password.success' | t | default: 'We have sent you an email with a link to update your password.' }}</p>
      {%- endif -%}
      {{ form.errors | default_errors }}
      <label class="customer__label" for="recover_email">{{ 'customer.recover_password.email' | t | default: 'Email' }}</label>
      <input type="email" name="email" id="recover_email" class="customer__input" autocomplete="email" required>
      <button type="submit" class="btn btn--primary btn--lg customer__submit">{{ 'customer.recover_password.submit' | t | default: 'Submit' }}</button>
    {%- endform -%}

    <p class="customer__alt">
      <a href="#login" class="customer__link" onclick="document.getElementById('login').hidden=false;document.getElementById('recover').hidden=true;return false;">
        {{ 'customer.recover_password.cancel' | t | default: 'Back to login' }}
      </a>
    </p>
  </div>
</div>
