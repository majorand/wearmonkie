<footer class="footer" role="contentinfo">
  <div class="footer__inner container">

    <div class="footer__col">
      <a href="{{ routes.root_url }}" class="footer__logo" aria-label="{{ shop.name }}">
        {%- if settings.footer_logo != blank -%}
          {{- settings.footer_logo | image_url: width: 180 | image_tag: loading: 'lazy', alt: shop.name -}}
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </a>
      {%- if settings.footer_tagline != blank -%}
        <p class="footer__tagline">{{ settings.footer_tagline }}</p>
      {%- endif -%}
      <div class="footer__socials">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}
          <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.73a8.26 8.26 0 0 0 4.84 1.56V6.84a4.85 4.85 0 0 1-1.07-.15z"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_pinterest_link != blank -%}
          <a href="{{ settings.social_pinterest_link }}" target="_blank" rel="noopener noreferrer" aria-label="Pinterest">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.08 3.14 9.43 7.63 11.17-.1-.97-.2-2.46.04-3.52.22-.95 1.47-6.23 1.47-6.23s-.37-.75-.37-1.86c0-1.75 1.01-3.06 2.27-3.06 1.07 0 1.59.8 1.59 1.77 0 1.08-.69 2.69-1.04 4.18-.3 1.25.62 2.27 1.84 2.27 2.21 0 3.7-2.85 3.7-6.22 0-2.57-1.74-4.37-4.22-4.37-2.87 0-4.56 2.15-4.56 4.38 0 .87.33 1.8.75 2.3.08.1.09.19.07.29-.08.31-.25 1-.28 1.13-.04.18-.14.22-.31.13-1.17-.54-1.9-2.26-1.9-3.63 0-2.96 2.15-5.68 6.2-5.68 3.25 0 5.78 2.32 5.78 5.41 0 3.23-2.03 5.82-4.84 5.82-.94 0-1.83-.49-2.14-1.07l-.58 2.18c-.21.81-.77 1.82-1.15 2.44.87.27 1.78.41 2.73.41 6.63 0 12-5.37 12-12S18.63 0 12 0z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- for i in (1..3) -%}
      {%- assign menu_handle = 'footer-menu-' | append: i -%}
      {%- assign menu_heading = 'settings.footer_menu_' | append: i | append: '_heading' -%}
      {%- if linklists[menu_handle].links.size > 0 -%}
        <div class="footer__col">
          <h4>{{ settings[menu_heading] | default: linklists[menu_handle].title }}</h4>
          <ul>
            {%- for link in linklists[menu_handle].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>

  <div class="footer__bottom container">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    <div class="footer__legal">
      {{ shop.privacy_policy.url | default: '#' | prepend: '<a href="' | append: '">Privacy Policy</a>' }}
      {{ shop.terms_of_service.url | default: '#' | prepend: '<a href="' | append: '">Terms of Service</a>' }}
    </div>
    <div class="footer__payments">
      {%- for type in shop.enabled_payment_types -%}
        {{ type | payment_type_svg_tag: class: 'payment-icon' }}
      {%- endfor -%}
    </div>
  </div>
</footer>
