{% comment %}
  Renders a product card.
  Usage: {% render 'product-card', product: product %}
{% endcomment %}

{%- liquid
  assign product_url = product.url
  assign title = product.title
  assign vendor = product.vendor
  assign price = product.price
  assign compare_price = product.compare_at_price
  assign featured_image = product.featured_image
  assign available = product.available
-%}

<div class="product-card">
  <a href="{{ product_url }}" class="product-card__link">
    <div class="product-card__img-wrap">
      {%- if featured_image != blank -%}
        {{
          featured_image
          | image_url: width: 600
          | image_tag:
            loading: 'lazy',
            alt: featured_image.alt | default: title,
            class: 'product-card__img',
            widths: '300, 400, 600',
            sizes: '(min-width: 1200px) 300px, (min-width: 768px) 25vw, 50vw'
        }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'product-card__img product-card__img--placeholder' }}
      {%- endif -%}

      {%- if product.available == false -%}
        <span class="badge badge--sold-out">Sold out</span>
      {%- elsif product.compare_at_price > product.price -%}
        <span class="badge badge--sale">
          {{ product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round }}% off
        </span>
      {%- elsif product.created_at > now | date: '%s' | minus: 604800 -%}
        <span class="badge badge--new">New</span>
      {%- endif -%}

      <div class="product-card__actions">
        <button class="btn-icon" aria-label="Quick view" data-product-id="{{ product.id }}">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        </button>
        <button class="btn-icon" aria-label="{{ 'products.product.add_to_wishlist' | t }}" data-product-id="{{ product.id }}">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </button>
      </div>
    </div>

    <div class="product-card__info">
      {%- if vendor != blank -%}
        <p class="product-card__brand">{{ vendor }}</p>
      {%- endif -%}
      <h3 class="product-card__name">{{ title }}</h3>

      {%- if product.metafields.reviews.rating.value != blank -%}
        <div class="product-card__stars" aria-label="{{ product.metafields.reviews.rating.value }} out of 5 stars">
          {%- for i in (1..5) -%}
            {%- if i <= product.metafields.reviews.rating.value -%}★{%- else -%}☆{%- endif -%}
          {%- endfor -%}
          <span>({{ product.metafields.reviews.rating_count.value }})</span>
        </div>
      {%- endif -%}

      <div class="product-card__price">
        {%- if compare_price > price -%}
          <span class="price price--sale">{{ price | money }}</span>
          <span class="price price--original">{{ compare_price | money }}</span>
        {%- else -%}
          <span class="price">
            {%- if product.price_varies -%}
              {{ 'products.product.price.from_price_html' | t: price: price | money }}
            {%- else -%}
              {{ price | money }}
            {%- endif -%}
          </span>
        {%- endif -%}
      </div>

      {%- assign color_option = product.options_by_name['Color'] -%}
      {%- if color_option -%}
        <div class="product-card__swatches">
          {%- for value in color_option.values limit: 5 -%}
            <span class="swatch" title="{{ value | escape }}" style="background:{{ value | downcase | replace: ' ', '' | prepend: '--swatch-' | append: ': ' }}"></span>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </a>

  {%- if available -%}
    <form action="{{ routes.cart_add_url }}" method="post" class="product-card__form">
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      <input type="hidden" name="quantity" value="1">
      <button type="submit" class="btn btn--add-cart" aria-label="{{ 'products.product.add_to_cart' | t }}: {{ title | escape }}">
        {{ 'products.product.add_to_cart' | t }}
      </button>
    </form>
  {%- else -%}
    <button class="btn btn--add-cart" disabled>{{ 'products.product.sold_out' | t }}</button>
  {%- endif -%}
</div>
