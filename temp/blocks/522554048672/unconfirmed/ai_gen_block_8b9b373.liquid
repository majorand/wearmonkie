{% doc %}
  @prompt
    Create a header logo text block that allows the merchant to customize the store name/logo text displayed at the top of the page. It should have a text input setting so the merchant can type whatever name they want to display, with styling options like font size and color. This should replace or work alongside the existing header logo area.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-header-logo-text-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-header-logo-text__link-{{ ai_gen_id }} {
    display: inline-block;
    text-decoration: none;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    text-transform: {{ block.settings.text_transform }};
    transition: color 0.3s ease;
  }

  .ai-header-logo-text__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-header-logo-text__link-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.8);
    }
  }
{% endstyle %}

<div class="ai-header-logo-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <a href="{{ routes.root_url }}" class="ai-header-logo-text__link-{{ ai_gen_id }}">
    {% if block.settings.logo_text != blank %}
      {{ block.settings.logo_text }}
    {% else %}
      {{ shop.name }}
    {% endif %}
  </a>
</div>

{% schema %}
{
  "name": "Header logo text",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "WearMonkie"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "hover_color",
      "label": "Hover color",
      "default": "#666666"
    }
  ],
  "presets": [
    {
      "name": "Header logo text"
    }
  ]
}
{% endschema %}
