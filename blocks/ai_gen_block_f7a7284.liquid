{% doc %}
  @prompt
    Replace the password page content so that instead of showing "Are you the store owner?" with a password entry field, it shows a "Join the Waitlist" section where visitors can enter their email address to sign up for the waitlist. The form should collect email addresses and have a submit button labeled "Join the Waitlist"., make it where i can change the background photo of that, make it longer to fit a laptop and mobile screen
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-waitlist-signup-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: 80px 20px;
    text-align: center;
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-waitlist-signup__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .ai-waitlist-signup__background-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-waitlist-signup__background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-waitlist-signup__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.1;
  }

  .ai-waitlist-signup__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  .ai-waitlist-signup__container-{{ ai_gen_id }} {
    max-width: 600px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
    padding: 0 20px;
  }

  .ai-waitlist-signup__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 24px;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-waitlist-signup__subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 40px;
    line-height: 1.6;
  }

  .ai-waitlist-signup__form-wrapper-{{ ai_gen_id }} {
    margin-bottom: 16px;
  }

  .ai-waitlist-signup__form-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 12px;
  }

  .ai-waitlist-signup__input-{{ ai_gen_id }} {
    width: 100%;
    padding: 18px 20px;
    font-size: 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
  }

  .ai-waitlist-signup__input-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.button_color }};
    outline-offset: 2px;
  }

  .ai-waitlist-signup__button-{{ ai_gen_id }} {
    width: 100%;
    padding: 18px 40px;
    font-size: 16px;
    font-weight: 600;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-waitlist-signup__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-waitlist-signup__success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    font-size: 14px;
    margin-top: 8px;
  }

  .ai-waitlist-signup__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    font-size: 14px;
    margin-top: 8px;
  }

  @media screen and (min-width: 750px) {
    .ai-waitlist-signup__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 1.2);
    }

    .ai-waitlist-signup__subtext-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 1.1);
    }

    .ai-waitlist-signup__form-field-{{ ai_gen_id }} {
      flex-direction: row;
      align-items: flex-start;
    }

    .ai-waitlist-signup__input-{{ ai_gen_id }} {
      flex: 1;
    }

    .ai-waitlist-signup__button-{{ ai_gen_id }} {
      width: auto;
      white-space: nowrap;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-waitlist-signup-{{ ai_gen_id }} {
      min-height: 100svh;
      padding: 60px 20px;
    }
  }
{% endstyle %}

<waitlist-signup-{{ ai_gen_id }}
  class="ai-waitlist-signup-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-waitlist-signup__background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-waitlist-signup__background-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-waitlist-signup__background-placeholder-{{ ai_gen_id }}">
        {{ 'lifestyle-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-waitlist-signup__overlay-{{ ai_gen_id }}"></div>

  <div class="ai-waitlist-signup__container-{{ ai_gen_id }}">
    {%- if block.settings.heading != blank -%}
      <h2 class="ai-waitlist-signup__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if block.settings.subtext != blank -%}
      <div class="ai-waitlist-signup__subtext-{{ ai_gen_id }}">
        {{ block.settings.subtext }}
      </div>
    {%- endif -%}

    {%- form 'customer' -%}
      <input type="hidden" name="contact[tags]" value="waitlist">
      
      <div class="ai-waitlist-signup__form-wrapper-{{ ai_gen_id }}">
        <div class="ai-waitlist-signup__form-field-{{ ai_gen_id }}">
          <input
            type="email"
            name="contact[email]"
            class="ai-waitlist-signup__input-{{ ai_gen_id }}"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="ai-waitlist-signup-error-{{ ai_gen_id }}"
            {% endif %}
            {% if form.posted_successfully? %}
              aria-describedby="ai-waitlist-signup-success-{{ ai_gen_id }}"
            {% endif %}
            placeholder="{{ block.settings.email_placeholder }}"
            required
          >
          <button
            type="submit"
            class="ai-waitlist-signup__button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_label }}
          </button>
        </div>

        {%- if form.errors -%}
          <div
            id="ai-waitlist-signup-error-{{ ai_gen_id }}"
            class="ai-waitlist-signup__error-{{ ai_gen_id }}"
          >
            <span>{{ form.errors.messages.email }}</span>
          </div>
        {%- endif -%}

        {%- if form.posted_successfully? -%}
          <div
            id="ai-waitlist-signup-success-{{ ai_gen_id }}"
            class="ai-waitlist-signup__success-{{ ai_gen_id }}"
          >
            <span>{{ block.settings.success_message }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endform -%}
  </div>
</waitlist-signup-{{ ai_gen_id }}>

<script>
  (function() {
    class WaitlistSignup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.form = this.querySelector('form');
        if (this.form) {
          this.form.addEventListener('submit', this.handleSubmit.bind(this));
        }
      }

      handleSubmit(event) {
        const emailInput = this.form.querySelector('input[type="email"]');
        if (emailInput && !emailInput.value.trim()) {
          event.preventDefault();
        }
      }
    }

    customElements.define('waitlist-signup-{{ ai_gen_id }}', WaitlistSignup{{ ai_gen_id }});
  })();
</script>

