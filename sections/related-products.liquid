{%- liquid
  assign related_products = product.collections.first.products | where: 'id', '!=', product.id
  assign products_to_show = section.settings.products_to_show | default: 4
-%}

{%- if related_products.size > 0 -%}
  <section class="featured section container">
    <div class="section__header">
      <h2 class="section__title">{{ section.settings.heading }}</h2>
    </div>
    <div class="products__grid">
      {%- for product in related_products limit: products_to_show -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Related Products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "You May Also Like" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 6, "step": 1, "label": "Products to show", "default": 4 }
  ],
  "presets": [{ "name": "Related Products" }]
}
{% endschema %}
