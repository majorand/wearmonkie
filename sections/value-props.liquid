{%- liquid
  assign cols = section.blocks.size
-%}

<section class="vprops section container" style="--vprops-cols: {{ cols }};">
  {%- if section.settings.heading != blank -%}
    <div class="vprops__intro">
      {%- if section.settings.eyebrow != blank -%}
        <p class="vprops__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h2 class="section__title vprops__title">{{ section.settings.heading | escape }}</h2>
    </div>
  {%- endif -%}

  <div class="vprops__grid">
    {%- for block in section.blocks -%}
      <div class="vprop" {{ block.shopify_attributes }} style="--i: {{ forloop.index0 }};">
        <span class="vprop__icon" aria-hidden="true">
          {%- case block.settings.icon -%}
            {%- when 'leaf' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
            {%- when 'truck' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="1" y="4" width="14" height="12" rx="1"/><path d="M15 8h4l3 3v5h-7z"/><circle cx="5.5" cy="18.5" r="2"/><circle cx="18" cy="18.5" r="2"/></svg>
            {%- when 'sparkle' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2l2.2 6.3L20.5 10l-6.3 2.2L12 18.5l-2.2-6.3L3.5 10l6.3-1.7z"/></svg>
            {%- when 'heart' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21.2l7.8-7.8 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg>
            {%- when 'hanger' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 7a2 2 0 1 1 2-2"/><path d="M12 7v2l9 6.5a1.5 1.5 0 0 1-.9 2.7H3.9a1.5 1.5 0 0 1-.9-2.7L12 9"/></svg>
            {%- when 'gift' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="8" width="18" height="4"/><path d="M12 8v13M5 12v9h14v-9"/><path d="M12 8S10.5 3 8 3a2.5 2.5 0 0 0 0 5zM12 8s1.5-5 4-5a2.5 2.5 0 0 1 0 5z"/></svg>
            {%- when 'shield' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
            {%- else -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>
          {%- endcase -%}
        </span>
        {%- if block.settings.heading != blank -%}
          <h3 class="vprop__heading">{{ block.settings.heading | escape }}</h3>
        {%- endif -%}
        {%- if block.settings.text != blank -%}
          <p class="vprop__text">{{ block.settings.text | escape }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
.vprops { text-align: center; }
.vprops__intro { max-width: 620px; margin: 0 auto 3rem; }
.vprops__eyebrow {
  font-size: 12px; font-weight: 600; letter-spacing: .16em; text-transform: uppercase;
  color: var(--color-accent-dark); margin-bottom: .75rem;
}
.vprops__title { margin-bottom: 0; }
.vprops__grid {
  display: grid;
  grid-template-columns: repeat(var(--vprops-cols, 4), 1fr);
  gap: 1.25rem;
}
.vprop {
  padding: 2.5rem 1.5rem;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  background: var(--color-surface);
  display: flex; flex-direction: column; align-items: center; gap: .85rem;
  transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
}
.vprop:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); border-color: var(--color-accent); }
.vprop__icon {
  width: 56px; height: 56px; border-radius: 50%;
  display: grid; place-items: center;
  background: var(--color-bg); color: var(--color-accent-dark);
  transition: background var(--transition), color var(--transition);
}
.vprop:hover .vprop__icon { background: var(--color-dark); color: #fff; }
.vprop__icon svg { width: 26px; height: 26px; }
.vprop__heading { font-size: 15px; font-weight: 600; color: var(--color-dark); letter-spacing: .02em; }
.vprop__text { font-size: 13px; color: var(--color-text-muted); line-height: 1.6; max-width: 28ch; }
@media (max-width: 1024px) { .vprops__grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 540px) { .vprops__grid { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Value Props",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The WearMonkie Promise" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Designed Around Real Life" }
  ],
  "blocks": [
    {
      "type": "prop",
      "name": "Value prop",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          { "value": "leaf", "label": "Leaf" },
          { "value": "truck", "label": "Truck" },
          { "value": "sparkle", "label": "Sparkle" },
          { "value": "heart", "label": "Heart" },
          { "value": "hanger", "label": "Hanger" },
          { "value": "gift", "label": "Gift" },
          { "value": "shield", "label": "Shield" },
          { "value": "check", "label": "Check" }
        ], "default": "sparkle" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Considered Fabrics" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Breathable, durable materials that move with you all day." }
      ]
    }
  ],
  "presets": [{
    "name": "Value Props",
    "blocks": [
      { "type": "prop", "settings": { "icon": "leaf", "heading": "Sustainably Sourced", "text": "Responsibly made fabrics, lower-impact production." } },
      { "type": "prop", "settings": { "icon": "hanger", "heading": "Inclusive Sizing", "text": "Thoughtful fits from XS to 3X — for every body." } },
      { "type": "prop", "settings": { "icon": "truck", "heading": "Fast, Free Shipping", "text": "Complimentary delivery on every order over $75." } },
      { "type": "prop", "settings": { "icon": "heart", "heading": "Loved by 50k+", "text": "A community of women who dress for themselves." } }
    ]
  }]
}
{% endschema %}
