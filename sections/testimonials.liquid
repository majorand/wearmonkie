<section class="testimonials section" data-testimonials>
  <div class="container">
    <div class="testimonials__head">
      {%- if section.settings.eyebrow != blank -%}
        <p class="testimonials__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="testimonials__title">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.rating_text != blank -%}
        <p class="testimonials__rating">
          <span class="testimonials__stars" aria-hidden="true">★★★★★</span>
          {{ section.settings.rating_text | escape }}
        </p>
      {%- endif -%}
    </div>

    <div class="testimonials__viewport">
      <ul class="testimonials__track" data-track>
        {%- for block in section.blocks -%}
          <li class="testimonial" {{ block.shopify_attributes }}>
            <blockquote class="testimonial__card">
              <span class="testimonial__quote" aria-hidden="true">&ldquo;</span>
              <span class="testimonial__stars" aria-label="{{ block.settings.rating | default: 5 }} out of 5 stars">
                {%- assign r = block.settings.rating | default: 5 -%}
                {%- for i in (1..5) -%}{%- if i <= r -%}★{%- else -%}☆{%- endif -%}{%- endfor -%}
              </span>
              <p class="testimonial__body">{{ block.settings.quote | escape }}</p>
              <footer class="testimonial__footer">
                {%- if block.settings.avatar != blank -%}
                  <span class="testimonial__avatar">
                    {{ block.settings.avatar | image_url: width: 96 | image_tag: loading: 'lazy', alt: block.settings.name }}
                  </span>
                {%- else -%}
                  <span class="testimonial__avatar testimonial__avatar--initial">{{ block.settings.name | slice: 0 | upcase }}</span>
                {%- endif -%}
                <span class="testimonial__who">
                  <strong>{{ block.settings.name | default: 'Verified Buyer' | escape }}</strong>
                  {%- if block.settings.detail != blank -%}<span>{{ block.settings.detail | escape }}</span>{%- endif -%}
                </span>
              </footer>
            </blockquote>
          </li>
        {%- endfor -%}
      </ul>
    </div>

    {%- if section.blocks.size > 1 -%}
      <div class="testimonials__nav">
        <button class="testimonials__arrow" data-prev aria-label="Previous testimonials" type="button">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="testimonials__arrow" data-next aria-label="Next testimonials" type="button">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.testimonials { background: #f3ede8; }
.testimonials__head { text-align: center; max-width: 640px; margin: 0 auto 3rem; }
.testimonials__eyebrow {
  font-size: 12px; font-weight: 600; letter-spacing: .16em; text-transform: uppercase;
  color: var(--color-accent-dark); margin-bottom: .75rem;
}
.testimonials__title {
  font-family: var(--font-serif); font-size: clamp(1.9rem, 3.4vw, 2.8rem);
  font-weight: 700; color: var(--color-dark); margin-bottom: .85rem;
}
.testimonials__rating { font-size: 14px; color: var(--color-text-muted); display: inline-flex; align-items: center; gap: .5rem; }
.testimonials__stars { color: #d4a017; letter-spacing: .05em; }
.testimonials__viewport { overflow: hidden; }
.testimonials__track {
  display: flex; gap: 1.5rem;
  transition: transform .5s cubic-bezier(.22,.61,.36,1);
}
.testimonial { flex: 0 0 calc((100% - 3rem) / 3); }
.testimonial__card {
  position: relative; background: var(--color-surface);
  border: 1px solid var(--color-border); border-radius: var(--radius-lg);
  padding: 2rem 1.75rem 1.75rem; height: 100%;
  display: flex; flex-direction: column;
}
.testimonial__quote {
  font-family: var(--font-serif); font-size: 3.5rem; line-height: .6;
  color: var(--color-accent); opacity: .55; margin-bottom: .5rem;
}
.testimonial__stars { color: #d4a017; font-size: 14px; letter-spacing: .08em; margin-bottom: .75rem; }
.testimonial__body { font-size: 15px; line-height: 1.7; color: var(--color-text); margin-bottom: 1.5rem; flex: 1; }
.testimonial__footer { display: flex; align-items: center; gap: .85rem; }
.testimonial__avatar { width: 44px; height: 44px; border-radius: 50%; overflow: hidden; flex-shrink: 0; }
.testimonial__avatar img { width: 100%; height: 100%; object-fit: cover; }
.testimonial__avatar--initial {
  display: grid; place-items: center; background: var(--color-accent); color: #fff;
  font-weight: 700; font-size: 16px;
}
.testimonial__who { display: flex; flex-direction: column; line-height: 1.35; }
.testimonial__who strong { font-size: 14px; color: var(--color-dark); }
.testimonial__who span { font-size: 12px; color: var(--color-text-muted); }
.testimonials__nav { display: flex; justify-content: center; gap: .75rem; margin-top: 2.25rem; }
.testimonials__arrow {
  width: 46px; height: 46px; border-radius: 50%;
  border: 1.5px solid var(--color-border); background: var(--color-surface);
  display: grid; place-items: center; color: var(--color-dark);
  transition: all var(--transition);
}
.testimonials__arrow svg { width: 20px; height: 20px; }
.testimonials__arrow:hover { background: var(--color-dark); color: #fff; border-color: var(--color-dark); }
.testimonials__arrow:disabled { opacity: .35; cursor: not-allowed; }
@media (max-width: 1024px) { .testimonial { flex-basis: calc((100% - 1.5rem) / 2); } }
@media (max-width: 640px) { .testimonial { flex-basis: 100%; } }
{% endstylesheet %}

{% javascript %}
(function () {
  document.querySelectorAll('[data-testimonials]').forEach(function (root) {
    var track = root.querySelector('[data-track]');
    var prev = root.querySelector('[data-prev]');
    var next = root.querySelector('[data-next]');
    if (!track || !prev || !next) return;
    var index = 0;

    function perView() {
      var w = window.innerWidth;
      if (w <= 640) return 1;
      if (w <= 1024) return 2;
      return 3;
    }
    function maxIndex() { return Math.max(0, track.children.length - perView()); }
    function render() {
      index = Math.min(index, maxIndex());
      var item = track.children[0];
      if (!item) return;
      var style = window.getComputedStyle(track);
      var gap = parseFloat(style.columnGap || style.gap || '0') || 0;
      var step = item.getBoundingClientRect().width + gap;
      track.style.transform = 'translateX(' + (-index * step) + 'px)';
      prev.disabled = index <= 0;
      next.disabled = index >= maxIndex();
    }
    prev.addEventListener('click', function () { index = Math.max(0, index - 1); render(); });
    next.addEventListener('click', function () { index = Math.min(maxIndex(), index + 1); render(); });
    window.addEventListener('resize', render);
    render();
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Worn & Loved" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What She's Saying" },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "4.9 / 5 from 12,000+ reviews" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Rating", "default": 5 },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "The fit is unreal — finally a brand that gets curves right. I've ordered four more pieces since." },
        { "type": "text", "id": "name", "label": "Name", "default": "Maya R." },
        { "type": "text", "id": "detail", "label": "Detail", "default": "Verified Buyer · Size L" },
        { "type": "image_picker", "id": "avatar", "label": "Avatar" }
      ]
    }
  ],
  "presets": [{
    "name": "Testimonials",
    "blocks": [
      { "type": "testimonial", "settings": { "quote": "The fit is unreal — finally a brand that gets curves right. I've ordered four more pieces since.", "name": "Maya R.", "detail": "Verified Buyer · Size L" } },
      { "type": "testimonial", "settings": { "quote": "Quality you can feel the second you open the box. These have become my everyday go-tos.", "name": "Priya S.", "detail": "Verified Buyer · Size M" } },
      { "type": "testimonial", "settings": { "quote": "Sustainable, size-inclusive, and genuinely beautiful. WearMonkie is my whole closet now.", "name": "Dana L.", "detail": "Verified Buyer · Size XL" } },
