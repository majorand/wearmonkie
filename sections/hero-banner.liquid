<section class="hero" aria-label="{{ section.settings.heading | escape }}">
  <div class="hero__media">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1600
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          class: 'hero__img',
          alt: section.settings.image.alt | default: section.settings.heading,
          widths: '750, 1100, 1500, 1780, 2000',
          sizes: '100vw'
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__img hero__img--placeholder' }}
    {%- endif -%}
    <div class="hero__overlay" style="opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  </div>

  <div class="hero__content container">
    {%- if section.settings.eyebrow != blank -%}
      <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="hero__title">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="hero__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
    <div class="hero__ctas">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn--primary">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_button_label != blank -%}
        <a href="{{ section.settings.secondary_button_url | default: '#' }}" class="btn btn--ghost">
          {{ section.settings.secondary_button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 80, "step": 5, "unit": "%", "label": "Overlay opacity", "default": 50 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Summer 2025 Collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Dress for the Life You Want" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Effortless styles made for real women." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop Now" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "text", "id": "secondary_button_label", "label": "Secondary button label", "default": "Explore Looks" },
    { "type": "url", "id": "secondary_button_url", "label": "Secondary button URL" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
