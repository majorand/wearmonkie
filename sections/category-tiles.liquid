<section class="categories section container">
  {%- if section.settings.heading != blank -%}
    <h2 class="section__title">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="categories__grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.url | default: '#' }}" class="cat-tile" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{
            block.settings.image
            | image_url: width: 600
            | image_tag:
              loading: 'lazy',
              alt: block.settings.label | default: block.settings.image.alt,
              class: 'cat-tile__img',
              widths: '300, 400, 600',
              sizes: '(min-width: 1024px) 25vw, 50vw'
          }}
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'cat-tile__img cat-tile__img--placeholder' }}
        {%- endif -%}
        {%- if block.settings.label != blank -%}
          <div class="cat-tile__label">{{ block.settings.label }}</div>
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Category Tiles",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Category" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "label", "label": "Label", "default": "Category" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "presets": [{
    "name": "Category Tiles",
    "blocks": [
      { "type": "tile", "settings": { "label": "Dresses" } },
      { "type": "tile", "settings": { "label": "Tops" } },
      { "type": "tile", "settings": { "label": "Bottoms" } },
      { "type": "tile", "settings": { "label": "Outerwear" } }
    ]
  }]
}
{% endschema %}
