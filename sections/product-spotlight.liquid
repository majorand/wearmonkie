{%- liquid
  assign product = all_products[section.settings.product]
-%}

<section class="spotlight section {% if section.settings.reverse %}spotlight--reverse{% endif %}" style="--spotlight-bg: {{ section.settings.background }};">
  <div class="spotlight__inner container">
    <div class="spotlight__media">
      {%- if product != blank and product.featured_image != blank -%}
        <a href="{{ product.url }}" class="spotlight__img-link">
          {{ product.featured_image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'spotlight__img', alt: product.title, widths: '500, 750, 1000', sizes: '(min-width: 1024px) 45vw, 100vw' }}
        </a>
      {%- elsif section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'spotlight__img', alt: section.settings.heading }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'spotlight__img spotlight__img--placeholder' }}
      {%- endif -%}
    </div>

    <div class="spotlight__body">
      {%- if section.settings.eyebrow != blank -%}
        <p class="spotlight__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      <h2 class="spotlight__title">
        {{ section.settings.heading | default: product.title | escape }}
      </h2>

      {%- if product != blank and product.metafields.reviews.rating.value != blank -%}
        <div class="spotlight__rating">
          <span class="spotlight__stars" aria-hidden="true">
            {%- assign rr = product.metafields.reviews.rating.value | round -%}
            {%- for i in (1..5) -%}{%- if i <= rr -%}★{%- else -%}☆{%- endif -%}{%- endfor -%}
          </span>
          <span>{{ product.metafields.reviews.rating_count.value }} reviews</span>
        </div>
      {%- endif -%}

      <div class="spotlight__price">
        {%- if product != blank -%}
          {%- if product.compare_at_price > product.price -%}
            <span class="price price--sale price--lg">{{ product.price | money }}</span>
            <span class="price price--original">{{ product.compare_at_price | money }}</span>
          {%- else -%}
            <span class="price price--lg">{{ product.price | money }}</span>
          {%- endif -%}
        {%- elsif section.settings.price != blank -%}
          <span class="price price--lg">{{ section.settings.price | escape }}</span>
        {%- endif -%}
      </div>

      {%- if section.settings.body != blank -%}
        <p class="spotlight__desc">{{ section.settings.body | escape }}</p>
      {%- elsif product != blank and product.description != blank -%}
        <p class="spotlight__desc">{{ product.description | strip_html | truncatewords: 38 }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="spotlight__features">
          {%- for b in section.blocks -%}
            <li {{ b.shopify_attributes }}>{{ b.settings.text | escape }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <div class="spotlight__ctas">
        {%- if product != blank and product.available -%}
          <form action="{{ routes.cart_add_url }}" method="post">
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <button type="submit" class="btn btn--primary btn--lg">{{ section.settings.button_label | default: 'Add to Bag' | escape }}</button>
          </form>
          <a href="{{ product.url }}" class="btn btn--outline btn--lg">View Details</a>
        {%- else -%}
          <a href="{{ product.url | default: section.settings.button_url | default: '#' }}" class="btn btn--primary btn--lg">
            {{ section.settings.button_label | default: 'Shop Now' | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
.spotlight { background: var(--spotlight-bg, #f3ede8); padding: clamp(3rem, 6vw, 5.5rem) 0; }
.spotlight__inner { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4.5rem); align-items: center; }
.spotlight--reverse .spotlight__media { order: 2; }
.spotlight__media { border-radius: var(--radius-lg); overflow: hidden; aspect-ratio: 4/5; box-shadow: var(--shadow-lg); }
.spotlight__img-link, .spotlight__img { display: block; width: 100%; height: 100%; }
.spotlight__img { object-fit: cover; transition: transform .8s ease; }
.spotlight__media:hover .spotlight__img { transform: scale(1.04); }
.spotlight__eyebrow {
  font-size: 12px; font-weight: 600; letter-spacing: .16em; text-transform: uppercase;
  color: var(--color-accent-dark); margin-bottom: 1rem;
}
.spotlight__title {
  font-family: var(--font-serif); font-size: clamp(2rem, 3.6vw, 3rem);
  font-weight: 700; line-height: 1.1; color: var(--color-dark); margin-bottom: .85rem; text-wrap: balance;
}
.spotlight__rating { display: flex; align-items: center; gap: .5rem; font-size: 13px; color: var(--color-text-muted); margin-bottom: 1rem; }
.spotlight__stars { color: #d4a017; letter-spacing: .05em; }
.spotlight__price { display: flex; align-items: baseline; gap: .75rem; margin-bottom: 1.25rem; }
.spotlight__desc { font-size: 15px; color: var(--color-text-muted); line-height: 1.75; margin-bottom: 1.5rem; max-width: 48ch; }
.spotlight__features {
  list-style: none; display: grid; gap: .6rem; margin-bottom: 2rem;
}
.spotlight__features li {
  position: relative; padding-left: 1.6rem; font-size: 14px; color: var(--color-dark);
}
.spotlight__features li::before {
  content: ''; position: absolute; left: 0; top: .5em; width: 8px; height: 8px;
  border-radius: 50%; background: var(--color-accent-dark);
}
.spotlight__ctas { display: flex; gap: .85rem; flex-wrap: wrap; }
@media (max-width: 768px) {
  .spotlight__inner { grid-template-columns: 1fr; }
  .spotlight--reverse .spotlight__media { order: 0; }
  .spotlight__media { aspect-ratio: 4/3; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Product Spotlight",
  "tag": "section",
  "settings": [
    { "type": "product", "id": "product", "label": "Featured product" },
    { "type": "checkbox", "id": "reverse", "label": "Image on right", "default": false },
    { "type": "color", "id": "background", "label": "Background color", "default": "#f3ede8" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Hero Piece" },
    { "type": "text", "id": "heading", "label": "Heading (overrides product title)" },
    { "type": "textarea", "id": "body", "label": "Description (overrides product description)" },
    { "type": "text", "id": "price", "label": "Price (if no product linked)" },
    { "type": "image_picker", "id": "image", "label": "Image (if no product linked)" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Add to Bag" },
    { "type": "url", "id": "button_url", "label": "Button link (if no product linked)" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Buttery-soft modal blend" }
      ]
    }
  ],
  "presets": [{
    "name": "Product Spotlight",
    "blocks": [
      { "type": "feature", "settings": { "text": "Buttery-soft modal blend" } },
      { "type": "feature", "settings": { "text": "Drapes beautifully on every frame" } },
      { "type": "feature", "settings": { "text": "Machine washable, never pills" } }
    ]
  }]
}
{% endschema %}
