{%- liquid
  assign show_watermark = section.settings.show_watermark
  assign watermark_image = section.settings.watermark_image
  assign watermark_filename = section.settings.watermark_filename | default: 'monkey.png'
  assign watermark_source = section.settings.watermark_source

  if watermark_image != blank
    assign watermark_url = watermark_image | image_url: width: 1300
  elsif watermark_source == 'files'
    assign watermark_url = watermark_filename | file_url
  else
    assign watermark_url = watermark_filename | asset_url
  endif
-%}

{%- if show_watermark and watermark_url != blank -%}
<style>
  .password-page {
    position: relative;
    overflow: hidden;
  }
  .password-page::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 350px;
    height: 350px;
    background-image: url("{{ watermark_url }}");
    background-repeat: no-repeat;
    background-position: center;
    background-size: contain;
    opacity: 0.12;
    z-index: 1;
    pointer-events: none;
  }
  .password-page__inner {
    position: relative;
    z-index: 2;
  }
  @media (min-width: 768px) {
    .password-page::before {
      width: 650px;
      height: 650px;
    }
  }
</style>
{%- endif -%}

<section class="password-page">
  <div class="password-page__inner">
    <h1 class="password-page__logo">{{ shop.name }}</h1>
    {%- if shop.password_message != blank -%}
      <div class="password-page__message">{{ shop.password_message }}</div>
    {%- else -%}
      <p class="password-page__tagline">{{ section.settings.tagline | default: 'Something beautiful is coming soon.' }}</p>
    {%- endif -%}

    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <p class="password-page__error" role="alert">{{ form.errors.translated_fields['password'] | capitalize }} {{ form.errors.messages['password'] }}</p>
      {%- endif -%}
      <div class="password-page__form">
        <input type="password" name="password" id="password" placeholder="{{ 'general.password_page.password_placeholder' | t | default: 'Enter store password' }}" aria-label="Password" required>
        <button type="submit" class="btn btn--primary">{{ 'general.password_page.enter' | t | default: 'Enter' }}</button>
      </div>
    {%- endform -%}

    <p class="password-page__admin">
      {{ 'general.password_page.admin_link_html' | t | default: 'Are you the store owner?' }}
      <a href="/admin">{{ 'general.password_page.login' | t | default: 'Log in here' }}</a>
    </p>
  </div>
</section>

{% stylesheet %}
.password-page { min-height: 100vh; display: grid; place-items: center; padding: 2rem; text-align: center; background: var(--color-bg); }
.password-page__inner { max-width: 460px; width: 100%; }
.password-page__logo { font-family: var(--font-serif); font-size: clamp(2.2rem, 6vw, 3.2rem); font-weight: 700; color: var(--color-dark); margin-bottom: 1rem; }
.password-page__tagline, .password-page__message { font-size: 16px; color: var(--color-text-muted); line-height: 1.7; margin-bottom: 2rem; }
.password-page__form { display: flex; gap: .5rem; max-width: 400px; margin: 0 auto 1.5rem; }
.password-page__form input { flex: 1; padding: .8rem 1.25rem; font-size: 15px; font-family: inherit; border: 1.5px solid var(--color-border); border-radius: var(--radius); background: var(--color-surface); outline: none; transition: border-color var(--transition); }
.password-page__form input:focus { border-color: var(--color-dark); }
.password-page__error { color: var(--color-sale); margin-bottom: 1rem; }
.password-page__admin { font-size: 13px; color: var(--color-text-muted); }
.password-page__admin a { color: var(--color-accent-dark); text-decoration: underline; }
@media (max-width: 480px) { .password-page__form { flex-direction: column; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Password",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Something beautiful is coming soon."
    },
    {
      "type": "header",
      "content": "Watermark Background"
    },
    {
      "type": "checkbox",
      "id": "show_watermark",
      "label": "Show watermark",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "watermark_image",
      "label": "Watermark Image",
      "info": "Upload the monkey image here or configure it below."
    },
    {
      "type": "text",
      "id": "watermark_filename",
      "label": "Watermark Filename (Fallback)",
      "default": "monkey.png",
      "info": "If no image is uploaded above, enter the filename here."
    },
    {
      "type": "select",
      "id": "watermark_source",
      "label": "Watermark Fallback Source",
      "options": [
        { "value": "assets", "label": "Shopify Assets folder" },
        { "value": "files", "label": "Shopify Files" }
      ],
      "default": "assets"
    }
  ]
}
{% endschema %}