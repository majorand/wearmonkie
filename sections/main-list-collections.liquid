<div class="page-header">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t | default: 'Home' }}</a> /
      <span aria-current="page">{{ section.settings.heading | default: 'Collections' }}</span>
    </nav>
    <h1 class="page-header__title">{{ section.settings.heading | default: 'Collections' }}</h1>
  </div>
</div>

<div class="section container">
  <div class="categories__grid collections-list">
    {%- assign collection_list = collections -%}
    {%- if section.settings.sort == 'alphabetical' -%}
      {%- assign collection_list = collections | sort: 'title' -%}
    {%- endif -%}
    {%- for collection in collection_list -%}
      {%- if collection.handle == 'frontpage' -%}{% continue %}{%- endif -%}
      <a href="{{ collection.url }}" class="cat-tile">
        {%- if collection.featured_image != blank -%}
          {{
            collection.featured_image
            | image_url: width: 600
            | image_tag:
              loading: 'lazy',
              class: 'cat-tile__img',
              alt: collection.title,
              widths: '300, 400, 600',
              sizes: '(min-width: 1024px) 25vw, 50vw'
          }}
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'cat-tile__img cat-tile__img--placeholder' }}
        {%- endif -%}
        <div class="cat-tile__label">{{ collection.title }}</div>
      </a>
    {%- else -%}
      <p>{{ 'sections.collection_template.empty' | t | default: 'No collections found.' }}</p>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Collections list",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop Collections" },
    { "type": "select", "id": "sort", "label": "Sort", "options": [
      { "value": "default", "label": "Default" },
      { "value": "alphabetical", "label": "Alphabetical" }
    ], "default": "default" }
  ]
}
{% endschema %}
