<div class="container">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t | default: 'Home' }}</a> /
    {%- if collection -%}
      <a href="{{ collection.url }}">{{ collection.title }}</a> /
    {%- endif -%}
    <span aria-current="page">{{ product.title }}</span>
  </nav>
</div>

{%- assign selected_variant = product.selected_or_first_available_variant -%}

<section class="product-detail container" itemscope itemtype="https://schema.org/Product">

  <!-- GALLERY -->
  <div class="product-gallery">
    <div class="product-gallery__thumbs">
      {%- for image in product.images limit: 6 -%}
        <button
          class="thumb{% if forloop.first %} active{% endif %}"
          data-src="{{ image | image_url: width: 800 }}"
          aria-label="{{ 'products.product.media.load_image' | t | default: 'Load image' }} {{ forloop.index }}"
        >
          {{
            image
            | image_url: width: 120
            | image_tag: loading: 'lazy', alt: image.alt | default: product.title
          }}
        </button>
      {%- else -%}
        <button class="thumb active">
          {{ 'product-1' | placeholder_svg_tag }}
        </button>
      {%- endfor -%}
    </div>
    <div class="product-gallery__main">
      {%- if product.featured_image != blank -%}
        {{
          product.featured_image
          | image_url: width: 800
          | image_tag:
            id: 'mainImg',
            loading: 'eager',
            alt: product.featured_image.alt | default: product.title,
            widths: '400, 600, 800',
            sizes: '(min-width: 1024px) 40vw, 100vw'
        }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag }}
      {%- endif -%}

      {%- if product.available == false -%}
        <span class="badge badge--sold-out" style="position:absolute;top:1rem;left:1rem;">{{ 'products.product.sold_out' | t | default: 'Sold Out' }}</span>
      {%- elsif product.compare_at_price > product.price -%}
        <span class="badge badge--sale" style="position:absolute;top:1rem;left:1rem;">Sale</span>
      {%- endif -%}
    </div>
  </div>

  <!-- PRODUCT INFO -->
  <div class="product-info" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
    <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
    <meta itemprop="price" content="{{ selected_variant.price | divided_by: 100.0 }}">
    <link itemprop="availability" href="https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}">

    {%- if section.settings.show_vendor and product.vendor != blank -%}
      <p class="product-info__brand" itemprop="brand">{{ product.vendor }}</p>
    {%- endif -%}

    <h1 class="product-info__title" itemprop="name">{{ product.title }}</h1>

    {%- if section.settings.show_rating and product.metafields.reviews.rating.value != blank -%}
      <div class="product-info__rating">
        <span class="stars" aria-hidden="true">
          {%- for i in (1..5) -%}
            {%- if i <= product.metafields.reviews.rating.value -%}★{%- else -%}☆{%- endif -%}
          {%- endfor -%}
        </span>
        <a href="#reviews" class="rating-link">
          {{ product.metafields.reviews.rating.value }} ({{ product.metafields.reviews.rating_count.value }} {{ 'products.product.reviews' | t | default: 'reviews' }})
        </a>
      </div>
    {%- endif -%}

    <div class="product-info__price">
      {%- if selected_variant.compare_at_price > selected_variant.price -%}
        <span class="price price--sale price--lg">{{ selected_variant.price | money }}</span>
        <span class="price price--original">{{ selected_variant.compare_at_price | money }}</span>
      {%- else -%}
        <span class="price price--lg">{{ selected_variant.price | money }}</span>
      {%- endif -%}
    </div>

    {%- if product.description != blank -%}
      <div class="product-info__desc" itemprop="description">{{ product.description }}</div>
    {%- endif -%}

    {%- form 'product', product, id: 'product-form', novalidate: 'novalidate' -%}
      <input type="hidden" name="id" value="{{ selected_variant.id }}" id="variant-id">

      {%- for option in product.options_with_values -%}
        <div class="product-option">
          {%- liquid
            assign is_color = false
            if option.name == 'Color' or option.name == 'Colour'
              assign is_color = true
            endif
          -%}
          <div class="product-option__labelrow">
            <p class="product-option__label">
              {{ option.name }}:
              <strong id="selected-{{ option.name | handleize }}">{{ option.selected_value }}</strong>
            </p>
          </div>

          {%- if is_color -%}
            <div class="swatch-group" role="radiogroup" aria-label="{{ option.name }}">
              {%- for value in option.values -%}
                <button
                  type="button"
                  class="swatch swatch--lg{% if value == option.selected_value %} active{% endif %}"
                  title="{{ value | escape }}"
                  data-option-index="{{ forloop.parentloop.index0 }}"
                  data-option-value="{{ value | escape }}"
                  aria-label="{{ value | escape }}"
                  aria-pressed="{{ value == option.selected_value }}"
                ></button>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="size-group" role="radiogroup" aria-label="{{ option.name }}">
              {%- for value in option.values -%}
                <button
                  type="button"
                  class="size-btn{% if value == option.selected_value %} active{% endif %}"
                  data-option-index="{{ forloop.parentloop.index0 }}"
                  data-option-value="{{ value | escape }}"
                  aria-label="{{ value | escape }}"
                  aria-pressed="{{ value == option.selected_value }}"
                >{{ value }}</button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}

      <div class="product-option">
        <p class="product-option__label">{{ 'products.product.quantity.label' | t | default: 'Quantity' }}</p>
        <div class="qty-selector">
          <button type="button" class="qty-btn" aria-label="{{ 'products.product.quantity.decrease' | t | default: 'Decrease quantity' }}"
            onclick="var q=document.getElementById('qty-input');q.value=Math.max(1,+q.value-1);">−</button>
          <input type="number" id="qty-input" name="quantity" value="1" min="1"
            class="qty-value" style="border:none;width:40px;text-align:center;font-weight:600;"
            aria-label="{{ 'products.product.quantity.input_label' | t: product: product.title | default: 'Quantity' }}">
          <button type="button" class="qty-btn" aria-label="{{ 'products.product.quantity.increase' | t | default: 'Increase quantity' }}"
            onclick="var q=document.getElementById('qty-input');q.value=+q.value+1;">+</button>
        </div>
      </div>

      <div class="product-info__ctas">
        <button
          type="submit"
          name="add"
          class="btn btn--primary btn--lg"
          style="flex:1;"
          {% unless selected_variant.available %}disabled{% endunless %}
        >
          {%- if selected_variant.available -%}
            {{ 'products.product.add_to_cart' | t | default: 'Add to Cart' }}
          {%- else -%}
            {{ 'products.product.sold_out' | t | default: 'Sold Out' }}
          {%- endif -%}
        </button>
        <button type="button" class="btn btn--outline btn--icon-only" aria-label="{{ 'products.product.add_to_wishlist' | t | default: 'Add to wishlist' }}">
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </button>
      </div>

    {%- endform -%}

    <div class="micro-trust">
      <span>
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        {{ 'products.product.trust.shipping' | t | default: 'Free shipping over $75' }}
      </span>
      <span>
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
        {{ 'products.product.trust.returns' | t | default: '30-day returns' }}
      </span>
      <span>
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        {{ 'products.product.trust.secure' | t | default: 'Secure checkout' }}
      </span>
    </div>

    <div class="accordion">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'accordion' -%}
            <details class="accordion__item" {{ block.shopify_attributes }}>
              <summary class="accordion__summary">{{ block.settings.heading }}</summary>
              <div class="accordion__body">{{ block.settings.content }}</div>
            </details>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Product",
  "settings": [
    { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": true },
    { "type": "checkbox", "id": "show_rating", "label": "Show rating", "default": true }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Product details" },
        { "type": "richtext", "id": "content", "label": "Content" }
      ]
    }
  ],
  "presets": [{
    "name": "Product",
    "blocks": [
      { "type": "accordion", "settings": { "heading": "Product Details" } },
      { "type": "accordion", "settings": { "heading": "Sizing & Fit" } },
      { "type": "accordion", "settings": { "heading": "Care Instructions" } },
      { "type": "accordion", "settings": { "heading": "Shipping & Returns" } }
    ]
  }]
}
{% endschema %}
