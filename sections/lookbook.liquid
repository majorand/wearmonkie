{%- liquid
  assign img = section.settings.image
-%}

<section class="lookbook section container">
  <div class="lookbook__head">
    {%- if section.settings.eyebrow != blank -%}
      <p class="lookbook__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="lookbook__title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p class="lookbook__intro">{{ section.settings.text | escape }}</p>
    {%- endif -%}
  </div>

  <div class="lookbook__stage">
    <div class="lookbook__media">
      {%- if img != blank -%}
        {{
          img
          | image_url: width: 1400
          | image_tag:
            loading: 'lazy',
            class: 'lookbook__img',
            alt: img.alt | default: section.settings.heading,
            widths: '600, 900, 1200, 1400',
            sizes: '(min-width: 1024px) 65vw, 100vw'
        }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'lookbook__img lookbook__img--placeholder' }}
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- assign product = all_products[block.settings.product] -%}
        <div
          class="lookbook-dot"
          style="left: {{ block.settings.x }}%; top: {{ block.settings.y }}%;"
          {{ block.shopify_attributes }}
        >
          <button class="lookbook-dot__btn" aria-label="{{ block.settings.label | default: product.title | escape }}" type="button">
            <span class="lookbook-dot__pulse"></span>
            <span class="lookbook-dot__core">+</span>
          </button>
          <div class="lookbook-dot__card" role="group">
            <a href="{{ product.url | default: block.settings.url | default: '#' }}" class="lookbook-dot__card-link">
              <div class="lookbook-dot__thumb">
                {%- if product != blank and product.featured_image != blank -%}
                  {{ product.featured_image | image_url: width: 160 | image_tag: loading: 'lazy', alt: product.title, widths: '120, 160' }}
                {%- elsif block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 160 | image_tag: loading: 'lazy', alt: block.settings.label }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: '' }}
                {%- endif -%}
              </div>
              <div class="lookbook-dot__meta">
                <p class="lookbook-dot__name">{{ block.settings.label | default: product.title | default: 'Featured piece' | escape }}</p>
                {%- if product != blank and product.price != blank -%}
                  <p class="lookbook-dot__price">{{ product.price | money }}</p>
                {%- elsif block.settings.price != blank -%}
                  <p class="lookbook-dot__price">{{ block.settings.price | escape }}</p>
                {%- endif -%}
                <span class="lookbook-dot__shop">Shop this →</span>
              </div>
            </a>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
.lookbook__head { max-width: 620px; margin-bottom: 2.5rem; }
.lookbook__eyebrow {
  font-size: 12px; font-weight: 600; letter-spacing: .16em; text-transform: uppercase;
  color: var(--color-accent-dark); margin-bottom: .65rem;
}
.lookbook__title {
  font-family: var(--font-serif); font-size: clamp(1.9rem, 3.4vw, 2.9rem);
  font-weight: 700; line-height: 1.1; color: var(--color-dark); margin-bottom: .75rem;
}
.lookbook__intro { font-size: 15px; color: var(--color-text-muted); line-height: 1.7; }
.lookbook__media {
  position: relative; border-radius: var(--radius-lg); overflow: hidden;
  aspect-ratio: 16/10; box-shadow: var(--shadow-lg);
}
.lookbook__img { width: 100%; height: 100%; object-fit: cover; }

.lookbook-dot { position: absolute; transform: translate(-50%, -50%); z-index: 2; }
.lookbook-dot__btn {
  position: relative; width: 34px; height: 34px; border-radius: 50%;
  background: rgba(255,255,255,.95); color: var(--color-dark);
  display: grid; place-items: center; font-size: 20px; font-weight: 300; line-height: 1;
  box-shadow: 0 2px 10px rgba(0,0,0,.25); transition: transform var(--transition), background var(--transition), color var(--transition);
}
.lookbook-dot__btn:hover, .lookbook-dot.is-open .lookbook-dot__btn {
  background: var(--color-dark); color: #fff; transform: scale(1.08);
}
.lookbook-dot__core { position: relative; z-index: 2; }
.lookbook-dot__pulse {
  position: absolute; inset: 0; border-radius: 50%;
  box-shadow: 0 0 0 0 rgba(255,255,255,.6); animation: lookbookPulse 2.4s ease-out infinite;
}
.lookbook-dot__card {
  position: absolute; bottom: calc(100% + 14px); left: 50%; transform: translate(-50%, 8px);
  width: 230px; background: var(--color-surface); border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg); padding: .6rem; opacity: 0; visibility: hidden;
  transition: opacity var(--transition), transform var(--transition), visibility var(--transition);
  z-index: 5;
}
.lookbook-dot__card::after {
  content: ''; position: absolute; top: 100%; left: 50%; transform: translateX(-50%);
  border: 8px solid transparent; border-top-color: var(--color-surface);
}
.lookbook-dot:hover .lookbook-dot__card,
.lookbook-dot.is-open .lookbook-dot__card,
.lookbook-dot:focus-within .lookbook-dot__card {
  opacity: 1; visibility: visible; transform: translate(-50%, 0);
}
.lookbook-dot__card-link { display: flex; gap: .75rem; align-items: center; }
.lookbook-dot__thumb { width: 64px; height: 84px; flex-shrink: 0; border-radius: var(--radius); overflow: hidden; }
.lookbook-dot__thumb img { width: 100%; height: 100%; object-fit: cover; }
.lookbook-dot__meta { min-width: 0; }
.lookbook-dot__name { font-size: 13px; font-weight: 600; color: var(--color-dark); line-height: 1.3; margin-bottom: .2rem; }
.lookbook-dot__price { font-size: 13px; font-weight: 600; color: var(--color-dark); margin-bottom: .35rem; }
.lookbook-dot__shop { font-size: 11px; letter-spacing: .04em; text-transform: uppercase; color: var(--color-accent-dark); font-weight: 600; }

@keyframes lookbookPulse {
  0% { box-shadow: 0 0 0 0 rgba(255,255,255,.55); }
  70% { box-shadow: 0 0 0 14px rgba(255,255,255,0); }
  100% { box-shadow: 0 0 0 0 rgba(255,255,255,0); }
}
@media (max-width: 768px) {
  .lookbook__media { aspect-ratio: 4/5; }
  .lookbook-dot__card { width: 200px; }
}
@media (prefers-reduced-motion: reduce) { .lookbook-dot__pulse { animation: none; } }
{% endstylesheet %}

{% javascript %}
document.querySelectorAll('.lookbook-dot__btn').forEach(function (btn) {
  btn.addEventListener('click', function (e) {
    e.preventDefault();
    var dot = btn.closest('.lookbook-dot');
    var wasOpen = dot.classList.contains('is-open');
    dot.closest('.lookbook__media').querySelectorAll('.lookbook-dot').forEach(function (d) { d.classList.remove('is-open'); });
    if (!wasOpen) dot.classList.add('is-open');
  });
});
document.addEventListener('click', function (e) {
  if (!e.target.closest('.lookbook-dot')) {
    document.querySelectorAll('.lookbook-dot.is-open').forEach(function (d) { d.classList.remove('is-open'); });
  }
});
{% endjavascript %}

{% schema %}
{
  "name": "Shoppable Lookbook",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop the Look" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "One Outfit, Endless Ways" },
    { "type": "textarea", "id": "text", "label": "Intro text", "default": "Tap the markers to shop each piece styled straight from our latest campaign." },
    { "type": "image_picker", "id": "image", "label": "Lookbook image" }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Hotspot",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "range", "id": "x", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Horizontal position", "default": 50 },
        { "type": "range", "id": "y", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Vertical position", "default": 50 },
        { "type": "text", "id": "label", "label": "Label (overrides product title)" },
        { "type": "text", "id": "price", "label": "Price (if no product linked)" },
        { "type": "image_picker", "id": "image", "label": "Thumbnail (if no product linked)" },
        { "type": "url", "id": "url", "label": "Link (if no product linked)" }
      ]
    }
  ],
  "presets": [{
    "name": "Shoppable Lookbook",
    "blocks": [
      { "type": "hotspot", "settings": { "x": 38, "y": 32, "label": "Silk Wrap Blouse", "price": "$98" } },
      { "type": "hotspot", "settings": { "x": 46, "y": 68, "label": "Tailored Wide-Leg Trouser", "price": "$128" } },
      { "type": "hotspot", "settings": { "x": 62, "y": 50, "label": "Leather Crossbody", "price": "$156" } }
    ]
  }]
}
{% endschema %}
