<article class="article">
  <div class="article__hero">
    <div class="container article__hero-inner">
      <nav class="breadcrumb breadcrumb--light" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t | default: 'Home' }}</a> /
        <a href="{{ blog.url }}">{{ blog.title }}</a>
      </nav>
      {%- if article.tags.size > 0 -%}<p class="article__tag">{{ article.tags.first }}</p>{%- endif -%}
      <h1 class="article__title">{{ article.title }}</h1>
      <p class="article__meta">{{ article.published_at | date: '%B %-d, %Y' }}{% if article.author %} &middot; {{ article.author }}{% endif %}</p>
    </div>
  </div>

  {%- if article.image != blank -%}
    <div class="article__image container">
      {{ article.image | image_url: width: 1400 | image_tag: loading: 'eager', alt: article.title, widths: '600, 900, 1200, 1400', sizes: '(min-width: 1024px) 900px, 100vw' }}
    </div>
  {%- endif -%}

  <div class="article__body container">
    <div class="rte">{{ article.content }}</div>

    {%- if blog.next_article or blog.previous_article -%}
      <nav class="article__nav" aria-label="More articles">
        {%- if blog.previous_article -%}<a href="{{ blog.previous_article.url }}" class="article__nav-link">&larr; {{ blog.previous_article.title | truncate: 40 }}</a>{%- else -%}<span></span>{%- endif -%}
        {%- if blog.next_article -%}<a href="{{ blog.next_article.url }}" class="article__nav-link article__nav-link--next">{{ blog.next_article.title | truncate: 40 }} &rarr;</a>{%- endif -%}
      </nav>
    {%- endif -%}

    {%- if article.comments_enabled? -%}
      <section class="article__comments">
        <h2 class="article__comments-title">{{ article.comments_count }} {{ 'sections.article.comments' | t | default: 'Comments' }}</h2>
        {%- if article.comments_count > 0 -%}
          {%- paginate article.comments by 10 -%}
            <ul class="comment-list">
              {%- for comment in article.comments -%}
                <li class="comment">
                  <p class="comment__author">{{ comment.author }}</p>
                  <div class="comment__body">{{ comment.content }}</div>
                </li>
              {%- endfor -%}
            </ul>
          {%- endpaginate -%}
        {%- endif -%}

        {%- form 'new_comment', article -%}
          {%- if form.posted_successfully? -%}
            <p class="comment-success" role="status">{{ 'sections.article.comment_success' | t | default: 'Thanks! Your comment was posted.' }}</p>
          {%- endif -%}
          <div class="comment-form">
            <input type="text" name="comment[author]" placeholder="{{ 'sections.article.name' | t | default: 'Name' }}" value="{{ form.author }}" required aria-label="Name" class="search-form__input">
            <input type="email" name="comment[email]" placeholder="{{ 'sections.article.email' | t | default: 'Email' }}" value="{{ form.email }}" required aria-label="Email" class="search-form__input">
            <textarea name="comment[body]" rows="4" placeholder="{{ 'sections.article.message' | t | default: 'Your comment' }}" required aria-label="Comment" class="search-form__input">{{ form.body }}</textarea>
            <button type="submit" class="btn btn--primary">{{ 'sections.article.submit' | t | default: 'Post Comment' }}</button>
          </div>
        {%- endform -%}
      </section>
    {%- endif -%}
  </div>
</article>

{% stylesheet %}
.article__hero { background: #f3ede8; padding: 3rem 0 2.5rem; }
.article__hero-inner { max-width: 760px; }
.breadcrumb--light a { color: var(--color-text-muted); }
.article__tag { font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--color-accent-dark); font-weight: 600; margin: 1rem 0 .5rem; }
.article__title { font-family: var(--font-serif); font-size: clamp(2rem, 4.5vw, 3.2rem); font-weight: 700; line-height: 1.1; color: var(--color-dark); margin-bottom: .75rem; text-wrap: balance; }
.article__meta { font-size: 14px; color: var(--color-text-muted); }
.article__image { max-width: 940px; margin: 2.5rem auto 0; }
.article__image img { border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); }
.article__body { max-width: 760px; padding-top: 2.5rem; padding-bottom: 4rem; }
.article__nav { display: flex; justify-content: space-between; gap: 1rem; margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border); font-size: 14px; font-weight: 600; }
.article__nav-link { color: var(--color-text-muted); transition: color var(--transition); }
.article__nav-link:hover { color: var(--color-dark); }
.article__nav-link--next { margin-left: auto; text-align: right; }
.article__comments { margin-top: 3.5rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
.article__comments-title { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 700; color: var(--color-dark); margin-bottom: 1.5rem; }
.comment-list { display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 2rem; }
.comment { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.25rem; }
.comment__author { font-weight: 700; color: var(--color-dark); margin-bottom: .4rem; }
.comment__body { font-size: 14px; color: var(--color-text-muted); line-height: 1.7; }
.comment-form { display: flex; flex-direction: column; gap: .75rem; max-width: 520px; }
.comment-form textarea { resize: vertical; }
.comment-success { color: var(--color-green); margin-bottom: 1rem; }
{% endstylesheet %}

{% schema %}
{
  "name": "Article",
  "tag": "section",
  "settings": []
}
{% endschema %}
