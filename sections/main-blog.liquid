<div class="page-header">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t | default: 'Home' }}</a> /
      <span aria-current="page">{{ blog.title }}</span>
    </nav>
    <h1 class="page-header__title">{{ blog.title }}</h1>
  </div>
</div>

<div class="section container">
  {%- paginate blog.articles by 9 -%}
    <div class="blog-grid">
      {%- for article in blog.articles -%}
        <article class="blog-card">
          <a href="{{ article.url }}" class="blog-card__link">
            <div class="blog-card__img-wrap">
              {%- if article.image != blank -%}
                {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'blog-card__img', alt: article.title, widths: '300, 450, 600', sizes: '(min-width: 768px) 33vw, 100vw' }}
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'blog-card__img blog-card__img--placeholder' }}
              {%- endif -%}
            </div>
            <div class="blog-card__body">
              {%- if article.tags.size > 0 -%}<p class="blog-card__tag">{{ article.tags.first }}</p>{%- endif -%}
              <h2 class="blog-card__title">{{ article.title }}</h2>
              <p class="blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 22 }}</p>
              <p class="blog-card__meta">{{ article.published_at | date: '%B %-d, %Y' }}{% if article.author %} &middot; {{ article.author }}{% endif %}</p>
            </div>
          </a>
        </article>
      {%- else -%}
        <p>{{ 'sections.blog.empty' | t | default: 'No articles yet — check back soon.' }}</p>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="pagination" aria-label="Pagination">
        {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}" class="pagination__btn pagination__next">{{ 'general.pagination.previous' | t | default: 'Prev' }}</a>{%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}<a href="{{ part.url }}" class="pagination__btn">{{ part.title }}</a>
          {%- else -%}<span class="pagination__btn pagination__btn--active">{{ part.title }}</span>{%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}<a href="{{ paginate.next.url }}" class="pagination__btn pagination__next">{{ 'general.pagination.next' | t | default: 'Next' }}</a>{%- endif -%}
      </nav>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% stylesheet %}
.blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
.blog-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden; transition: box-shadow var(--transition), transform var(--transition); }
.blog-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
.blog-card__img-wrap { aspect-ratio: 3/2; overflow: hidden; }
.blog-card__img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; }
.blog-card:hover .blog-card__img { transform: scale(1.04); }
.blog-card__body { padding: 1.25rem 1.25rem 1.5rem; }
.blog-card__tag { font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: var(--color-accent-dark); font-weight: 600; margin-bottom: .5rem; }
.blog-card__title { font-family: var(--font-serif); font-size: 1.3rem; font-weight: 700; line-height: 1.25; color: var(--color-dark); margin-bottom: .6rem; }
.blog-card__excerpt { font-size: 14px; color: var(--color-text-muted); line-height: 1.6; margin-bottom: .85rem; }
.blog-card__meta { font-size: 12px; color: var(--color-text-muted); }
@media (max-width: 1024px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 640px) { .blog-grid { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Blog posts",
  "tag": "section",
  "settings": []
}
{% endschema %}
