<section class="showcase section container {% if section.settings.reverse %}showcase--reverse{% endif %}">
  {%- assign collection = collections[section.settings.collection] -%}
  <div class="showcase__media">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1200
        | image_tag:
          loading: 'lazy',
          class: 'showcase__img',
          alt: section.settings.image.alt | default: section.settings.heading,
          widths: '500, 750, 1000, 1200',
          sizes: '(min-width: 1024px) 50vw, 100vw'
      }}
    {%- elsif collection != blank and collection.featured_image != blank -%}
      {{ collection.featured_image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'showcase__img', alt: collection.title }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'showcase__img showcase__img--placeholder' }}
    {%- endif -%}
    {%- if section.settings.badge != blank -%}
      <span class="showcase__badge">{{ section.settings.badge | escape }}</span>
    {%- endif -%}
  </div>

  <div class="showcase__body">
    {%- if section.settings.eyebrow != blank -%}
      <p class="showcase__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="showcase__title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <p class="showcase__text">{{ section.settings.body | escape }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="showcase__list">
        {%- for b in section.blocks -%}
          <li class="showcase__list-item" {{ b.shopify_attributes }}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
            {{ b.settings.text | escape }}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_url | default: collection.url | default: '#' }}" class="btn btn--dark btn--lg showcase__cta">
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.showcase {
  display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 5rem);
  align-items: center;
}
.showcase--reverse .showcase__media { order: 2; }
.showcase__media {
  position: relative; border-radius: var(--radius-lg); overflow: hidden;
  aspect-ratio: 4/5; box-shadow: var(--shadow-lg);
}
.showcase__img { width: 100%; height: 100%; object-fit: cover; transition: transform .8s ease; }
.showcase__media:hover .showcase__img { transform: scale(1.04); }
.showcase__badge {
  position: absolute; top: 1.25rem; left: 1.25rem;
  background: var(--color-dark); color: #fff;
  font-size: 11px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
  padding: .4rem .85rem; border-radius: 2px;
}
.showcase__eyebrow {
  font-size: 12px; font-weight: 600; letter-spacing: .16em; text-transform: uppercase;
  color: var(--color-accent-dark); margin-bottom: 1rem;
}
.showcase__title {
  font-family: var(--font-serif); font-size: clamp(2rem, 3.6vw, 3.1rem);
  font-weight: 700; line-height: 1.1; color: var(--color-dark); margin-bottom: 1.25rem;
  text-wrap: balance;
}
.showcase__text { font-size: 16px; color: var(--color-text-muted); line-height: 1.75; margin-bottom: 1.75rem; max-width: 46ch; }
.showcase__list { display: flex; flex-direction: column; gap: .75rem; margin-bottom: 2rem; }
.showcase__list-item {
  display: flex; align-items: center; gap: .75rem;
  font-size: 14px; color: var(--color-dark); font-weight: 500;
}
.showcase__list-item svg { width: 18px; height: 18px; color: var(--color-accent-dark); flex-shrink: 0; }
@media (max-width: 768px) {
  .showcase { grid-template-columns: 1fr; gap: 2rem; }
  .showcase--reverse .showcase__media { order: 0; }
  .showcase__media { aspect-ratio: 4/3; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Collection Showcase",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "reverse", "label": "Image on right", "default": false },
    { "type": "image_picker", "id": "image", "label": "Image (falls back to collection image)" },
    { "type": "collection", "id": "collection", "label": "Linked collection" },
    { "type": "text", "id": "badge", "label": "Image badge", "default": "New In" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Capsule" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Everyday Tailoring Edit" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Sharp, season-less pieces engineered to mix, match and outlast every trend cycle." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop the Edit" },
    { "type": "url", "id": "button_url", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature line",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Wrinkle-resistant stretch weave" }
      ]
    }
  ],
  "presets": [{
    "name": "Collection Showcase",
    "blocks": [
      { "type": "feature", "settings": { "text": "Wrinkle-resistant stretch weave" } },
      { "type": "feature", "settings": { "text": "Hidden comfort waistband" } },
      { "type": "feature", "settings": { "text": "Designed for sizes XS–3X" } }
    ]
  }]
}
{% endschema %}
