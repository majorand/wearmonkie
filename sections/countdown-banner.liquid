{%- liquid
  assign deadline = section.settings.deadline
-%}

<section
  class="countdown {% if section.settings.use_image %}countdown--image{% endif %}"
  data-countdown
  data-deadline="{{ deadline }}"
>
  {%- if section.settings.use_image and section.settings.image != blank -%}
    <div class="countdown__media">
      {{
        section.settings.image
        | image_url: width: 2000
        | image_tag:
          loading: 'lazy',
          class: 'countdown__img',
          alt: section.settings.image.alt | default: section.settings.heading,
          widths: '750, 1100, 1500, 2000',
          sizes: '100vw'
      }}
      <div class="countdown__scrim"></div>
    </div>
  {%- endif -%}

  <div class="countdown__inner container">
    {%- if section.settings.eyebrow != blank -%}
      <p class="countdown__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="countdown__title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="countdown__sub">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}

    <div class="countdown__clock" data-clock role="timer" aria-live="off">
      <div class="countdown__unit"><span class="countdown__num" data-days>00</span><span class="countdown__label">Days</span></div>
      <span class="countdown__colon" aria-hidden="true">:</span>
      <div class="countdown__unit"><span class="countdown__num" data-hours>00</span><span class="countdown__label">Hrs</span></div>
      <span class="countdown__colon" aria-hidden="true">:</span>
      <div class="countdown__unit"><span class="countdown__num" data-minutes>00</span><span class="countdown__label">Min</span></div>
      <span class="countdown__colon" aria-hidden="true">:</span>
      <div class="countdown__unit"><span class="countdown__num" data-seconds>00</span><span class="countdown__label">Sec</span></div>
    </div>

    <p class="countdown__expired" data-expired hidden>{{ section.settings.expired_text | default: 'This offer has ended — but new drops land every Friday.' | escape }}</p>

    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn--lg countdown__cta {% if section.settings.use_image %}btn--ghost{% else %}btn--outline countdown__cta--light{% endif %}">
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.countdown {
  position: relative; overflow: hidden;
  background: var(--color-dark); color: #fff;
  padding: clamp(3.5rem, 8vw, 6rem) 0; text-align: center;
}
.countdown__media { position: absolute; inset: 0; z-index: 0; }
.countdown__img { width: 100%; height: 100%; object-fit: cover; }
.countdown__scrim { position: absolute; inset: 0; background: rgba(15,12,14,.62); }
.countdown__inner { position: relative; z-index: 1; max-width: 760px; }
.countdown__eyebrow {
  font-size: 12px; font-weight: 600; letter-spacing: .2em; text-transform: uppercase;
  opacity: .82; margin-bottom: 1rem;
}
.countdown__title {
  font-family: var(--font-serif); font-size: clamp(2rem, 5vw, 3.6rem);
  font-weight: 700; line-height: 1.05; margin-bottom: .85rem; text-wrap: balance;
}
.countdown__sub { font-size: clamp(1rem, 1.4vw, 1.15rem); opacity: .85; margin-bottom: 2.25rem; }
.countdown__clock {
  display: inline-flex; align-items: flex-start; gap: .65rem; margin-bottom: 2rem;
}
.countdown__unit {
  display: flex; flex-direction: column; align-items: center;
  min-width: 78px;
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.16);
  border-radius: var(--radius-lg);
  padding: 1rem .75rem .75rem;
  backdrop-filter: blur(6px);
}
.countdown__num {
  font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 700; line-height: 1; font-variant-numeric: tabular-nums;
}
.countdown__label { font-size: 10px; letter-spacing: .18em; text-transform: uppercase; opacity: .7; margin-top: .5rem; }
.countdown__colon {
  font-family: var(--font-serif); font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 700;
  line-height: 1; padding-top: 1rem; opacity: .55;
}
.countdown__expired { font-size: 1.05rem; opacity: .9; margin-bottom: 1.5rem; }
.countdown__cta--light { color: #fff; border-color: rgba(255,255,255,.5); }
.countdown__cta--light:hover { border-color: #fff; background: rgba(255,255,255,.12); }
@media (max-width: 540px) {
  .countdown__unit { min-width: 60px; padding: .75rem .5rem .6rem; }
  .countdown__colon { display: none; }
  .countdown__clock { gap: .5rem; }
}
{% endstylesheet %}

{% javascript %}
(function () {
  document.querySelectorAll('[data-countdown]').forEach(function (root) {
    var deadlineStr = root.getAttribute('data-deadline');
    var clock = root.querySelector('[data-clock]');
    var expired = root.querySelector('[data-expired]');
    var target = deadlineStr ? new Date(deadlineStr.replace(' ', 'T')).getTime() : NaN;
    if (isNaN(target)) { if (clock) clock.style.display = 'none'; return; }

    var els = {
      days: root.querySelector('[data-days]'),
      hours: root.querySelector('[data-hours]'),
      minutes: root.querySelector('[data-minutes]'),
      seconds: root.querySelector('[data-seconds]')
    };
    function pad(n) { return (n < 10 ? '0' : '') + n; }
    function tick() {
      var diff = target - Date.now();
      if (diff <= 0) {
        if (clock) clock.hidden = true;
        if (expired) expired.hidden = false;
        clearInterval(timer);
        return;
      }
      var s = Math.floor(diff / 1000);
      els.days.textContent = pad(Math.floor(s / 86400));
      els.hours.textContent = pad(Math.floor((s % 86400) / 3600));
      els.minutes.textContent = pad(Math.floor((s % 3600) / 60));
      els.seconds.textContent = pad(s % 60);
    }
    tick();
    var timer = setInterval(tick, 1000);
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "Countdown Banner",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Limited Time" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Summer Edit — 25% Off" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Our most-loved silhouettes, discounted for a few days only. When they're gone, they're gone." },
    { "type": "text", "id": "deadline", "label": "Deadline (YYYY-MM-DD HH:MM)", "info": "Store local time, 24-hour clock. Example: 2026-07-01 23:59", "default": "2026-07-01 23:59" },
    { "type": "text", "id": "expired_text", "label": "Expired message", "default": "This offer has ended — but new drops land every Friday." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop the Sale" },
    { "type": "url", "id": "button_url", "label": "Button link" },
    { "type": "header", "content": "Background" },
    { "type": "checkbox", "id": "use_image", "label": "Use background image", "default": false },
    { "type": "image_picker", "id": "image", "label": "Background image" }
  ],
  "presets": [{ "name": "Countdown Banner" }]
}
{% endschema %}
